# Headless CMS note: these variables connect your Next.js app to Sanity so portfolio content is editable from a CMS UI.
# NEXT_PUBLIC_SANITY_PROJECT_ID -> Sanity Manage dashboard > API > Project ID
# NEXT_PUBLIC_SANITY_DATASET -> usually "production" unless you created another dataset
# NEXT_PUBLIC_SANITY_API_VERSION -> date string for API behavior, format YYYY-MM-DD
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
NEXT_PUBLIC_FORMSPREE_ID=your_form_id_here